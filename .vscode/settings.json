{
  // ==========================================
  // Visual Studio Live Share セキュリティ設定
  // ==========================================

  // サインインしているゲストがセッションに参加する際に、ホスト（あなた）の承認を常に必須にします。
  // 意図しない人（リンクが漏れてしまった場合など）の自動参加を防ぎます。
  "liveshare.guestApprovalRequired": false,

  // 匿名（Microsoft アカウントや GitHub でサインインしていない）ゲストの参加リクエストをどう処理するかを設定します。
  // "reject" (自動拒否) にすることで、身元不明のユーザーのアクセスを完全にブロックします。
  // ※ "prompt" を指定すると都度承認を求めるようになります。
  "liveshare.anonymousGuestApproval": "accept",

  // 現在開いているワークスペース（フォルダ）の外部にあるファイルへのアクセスを制限します。
  // ゲストが意図せずパソコン内の他のシステムファイルやプライベートなファイルを閲覧してしまうのを防ぎます。
  "liveshare.shareExternalFiles": true,

  // ローカルで実行している Web サーバー等のポートを自動的に共有（公開）しないようにします。
  // false にすることで、ゲストに見せたいポートだけを手動で共有する安全な運用が可能になります。
  "liveshare.autoShareServers": true,

  // 【オプション設定】ネットワーク接続モードの指定
  // "auto" は P2P 接続を試み、失敗した場合は安全なクラウドリレーを使用します。
  // どうしてもクラウドリレーを経由させず、直接接続（P2P）のみに制限したい場合は "local" を指定します。
  // （※ "local" にするとネットワーク環境によっては接続できなくなることがあります）
  "liveshare.connectionMode": "auto"
}